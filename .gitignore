# dependencies
/node_modules
/.pnp
.pnp.js

# Next.js
/.next/
/out/

# environment variables — never commit real keys
.env*.local
.env

# build output
/build

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# secrets — never commit the real API key
Key.rtf

# local dev logs
dev-out.log
dev-err.log

# local editor / tool state
/.claude/*
!/.claude/agents/
/.vscode/

# TypeScript build cache
tsconfig.tsbuildinfo

# runtime-mutable demo data (local "Firestore" stand-in) — written by the app at
# runtime, NOT source of truth. The committed ground-truth seed (graph.json,
# expected-*.json/.md, secondary-insight-review.json, transcript-*.md) stays tracked.
/seed/latest-graph.json
/seed/latest-analysis.json
/seed/latest-insights.json
/seed/saved-sessions/
/seed/projects/
/seed/sessions/

# atomic-write temp files
*.tmp
